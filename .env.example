BINANCE_API_KEY=your_api_key
BINANCE_API_SECRET=your_api_secret
BINANCE_TESTNET=true
RUN_MODE=dry_run
QUOTE_ASSET=USDC
SYMBOLS=BTCUSDC,ETHUSDC,BNBUSDC,SOLUSDC
MEAN_REVERSION_ENABLED=true
MEAN_REVERSION_RSI_MAX=50
MEAN_REVERSION_PCT_DROP=-0.01
MAX_OPEN_TRADES=2
RESERVE_PCT=0.20
RISK_PCT=0.02
TAKE_PROFIT_PCT=0.04
STOP_LOSS_PCT=0.03
TREND_FOLLOW_ENABLED=true
TREND_FOLLOW_MAX_TRADES=2
TREND_FOLLOW_TRAILING_STOP_PCT=0.03
TREND_FOLLOW_RSI_MIN=45
TREND_FOLLOW_RSI_MAX=75
TREND_FOLLOW_VOLUME_MULTIPLIER=1.5
TREND_FOLLOW_VOLUME_PERIOD=20
TREND_FOLLOW_CROSSOVER_WINDOW=3
TREND_FOLLOW_EMA_SHORT=12
TREND_FOLLOW_EMA_LONG=26
LOG_LEVEL=INFO
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_REPORT_INTERVAL_HOURS=8
